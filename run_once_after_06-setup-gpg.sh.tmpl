{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# Setup GPG keys for git commit signing
# Configuration via chezmoi data (gpg.keys) and environment variables (BW_*)

set -euo pipefail

{{- if not .gpg.keys }}
echo "ℹ GPG keys 未設定（gpg.keys 為空）"
echo "  請在 ~/.config/chezmoi/chezmoi.toml 加入："
echo ""
echo "  [data.gpg]"
echo '  keys = ['
echo '    { id = "YOUR_KEY_ID", name = "Your Name", purpose = "work" },'
echo '  ]'
echo ""
echo "✓ GPG setup skipped — no keys configured"
exit 0
{{- end }}

GPG_KEYS=(
{{- range .gpg.keys }}
    "{{ .id }}|{{ .name }}|{{ .purpose }}"
{{- end }}
)

MISSING=()

echo "===== GPG Key 檢測 ====="
for entry in "${GPG_KEYS[@]}"; do
    IFS='|' read -r key_id name purpose <<< "$entry"
    if gpg --list-secret-keys "$key_id" &>/dev/null; then
        echo "✓ GPG key $key_id ($name) — $purpose"
    else
        echo "✗ GPG key $key_id ($name) — $purpose — 未找到"
        MISSING+=("$key_id|$name|$purpose")
    fi
done

if [[ ${#MISSING[@]} -eq 0 ]]; then
    echo ""
    echo "✓ GPG setup complete — all keys present"
    exit 0
fi

echo ""
echo "⚠ 缺少 ${#MISSING[@]} 個 GPG key，git commit 簽名將無法使用"
echo ""
read -rp "是否要設定 GPG key？(y/n) " SETUP_GPG

if [[ "$SETUP_GPG" != "y" && "$SETUP_GPG" != "Y" ]]; then
    echo "跳過 GPG 設定。之後可執行 chezmoi apply 重新設定。"
    exit 0
fi

# 檢查 bw CLI
if ! command -v bw &>/dev/null; then
    echo ""
    echo "✗ Bitwarden CLI 未安裝"
    read -rp "是否要安裝？(y/n) " INSTALL_BW
    if [[ "$INSTALL_BW" == "y" || "$INSTALL_BW" == "Y" ]]; then
        brew install bitwarden-cli
    else
        echo ""
        echo "手動匯入方式："
        for entry in "${MISSING[@]}"; do
            IFS='|' read -r key_id name purpose <<< "$entry"
            echo "  gpg --import ${purpose}.asc"
            echo "  gpg --import ${purpose}-public.asc"
            echo "  gpg --edit-key ${key_id} trust    # 選擇 5 (ultimate)"
        done
        exit 0
    fi
fi

# 設定 Bitwarden server（優先使用環境變數）
if [[ -n "${BW_SERVER:-}" ]]; then
    bw config server "$BW_SERVER" 2>/dev/null || true
    echo "✓ 使用 server: ${BW_SERVER} (from env)"
else
    echo ""
    echo "Bitwarden 伺服器："
    echo "  1) 官方 (bitwarden.com)"
    echo "  2) 自架 (Self-hosted)"
    read -rp "選擇 [1/2]: " BW_CHOICE

    case "$BW_CHOICE" in
        2)
            read -rp "輸入自架伺服器 URL (例如 https://vault.example.com): " BW_INPUT_SERVER
            bw config server "$BW_INPUT_SERVER" 2>/dev/null || true
            echo "✓ 已設定 server: $BW_INPUT_SERVER"
            ;;
        *)
            bw config server "https://vault.bitwarden.com" 2>/dev/null || true
            echo "✓ 使用官方 Bitwarden"
            ;;
    esac
fi

show_manual_instructions() {
    echo ""
    echo "請先手動登入 Bitwarden CLI 後重新執行："
    echo "  bw login"
    echo "  export BW_SESSION=\$(bw unlock --raw)"
    echo "  chezmoi apply"
    echo ""
    echo "或手動匯入 GPG key："
    for entry in "${MISSING[@]}"; do
        IFS='|' read -r key_id name purpose <<< "$entry"
        echo "  gpg --import ${purpose}.asc"
        echo "  gpg --import ${purpose}-public.asc"
        echo "  gpg --edit-key ${key_id} trust    # 選擇 5 (ultimate)"
    done
}

# 登入/解鎖（優先使用 API key）
BW_STATUS=$(bw status 2>/dev/null | jq -r '.status' 2>/dev/null || echo "unauthenticated")

if [[ "$BW_STATUS" == "unauthenticated" ]]; then
    if [[ -n "${BW_CLIENTID:-}" && -n "${BW_CLIENTSECRET:-}" ]]; then
        echo "使用 API key 登入..."
        BW_SESSION=$(bw login --apikey --raw 2>/dev/null) || { echo "✗ API key 登入失敗"; show_manual_instructions; exit 0; }
        export BW_SESSION
    else
        echo ""
        echo "請登入 Bitwarden："
        if ! bw login; then
            echo "✗ 登入失敗"
            show_manual_instructions
            exit 0
        fi
        echo ""
        echo "請解鎖取得 session："
        BW_SESSION=$(bw unlock --raw) || { echo "✗ 解鎖失敗"; show_manual_instructions; exit 0; }
        export BW_SESSION
    fi
elif [[ "$BW_STATUS" == "locked" ]]; then
    echo ""
    echo "請解鎖 Bitwarden："
    BW_SESSION=$(bw unlock --raw) || { echo "✗ 解鎖失敗"; show_manual_instructions; exit 0; }
    export BW_SESSION
else
    echo "✓ Bitwarden 已登入"
fi

# 同步 vault
bw sync &>/dev/null || true

# 搜尋 GPG item（優先使用環境變數指定的 item name）
BW_SEARCH="${BW_GPG_ITEM_NAME:-GPG}"
TMPDIR=$(mktemp -d)
trap "rm -rf $TMPDIR" EXIT

IMPORTED=0

for entry in "${MISSING[@]}"; do
    IFS='|' read -r key_id name purpose <<< "$entry"
    echo ""
    echo "搜尋 $name ($purpose) 的 GPG key..."

    ITEM_ID=$(bw list items --search "$BW_SEARCH" 2>/dev/null | \
        jq -r --arg purpose "$purpose" '.[] | select(.attachments != null) | select(.attachments[].fileName | test($purpose; "i")) | .id' | head -1)

    if [[ -z "$ITEM_ID" ]]; then
        echo "  ✗ 在 Bitwarden 中找不到 $purpose 的 GPG key 附件（搜尋: $BW_SEARCH）"
        continue
    fi

    for suffix in "" "-public"; do
        FILENAME="${purpose}${suffix}.asc"
        ATTACH_ID=$(bw get item "$ITEM_ID" 2>/dev/null | \
            jq -r --arg fn "$FILENAME" '.attachments[] | select(.fileName == $fn) | .id' 2>/dev/null | head -1)

        if [[ -n "$ATTACH_ID" ]]; then
            echo "  下載 $FILENAME..."
            if bw get attachment "$ATTACH_ID" --itemid "$ITEM_ID" --output "$TMPDIR/$FILENAME" 2>/dev/null; then
                if [[ -f "$TMPDIR/$FILENAME" ]]; then
                    echo "  匯入 $FILENAME..."
                    gpg --import "$TMPDIR/$FILENAME" 2>&1 || echo "  ⚠ $FILENAME 匯入時發生警告"
                fi
            else
                echo "  ✗ $FILENAME 下載失敗"
            fi
        else
            echo "  ⚠ 找不到附件 $FILENAME"
        fi
    done

    if gpg --list-secret-keys "$key_id" &>/dev/null; then
        echo "  ✓ $name ($key_id) 匯入成功"
        echo -e "5\ny\n" | gpg --command-fd 0 --expert --edit-key "$key_id" trust 2>/dev/null || true
        echo "  ✓ 信任等級已設定為 ultimate"
        IMPORTED=$((IMPORTED + 1))
    else
        echo "  ✗ $name ($key_id) 匯入失敗"
    fi
done

echo ""
if [[ $IMPORTED -eq ${#MISSING[@]} ]]; then
    echo "✓ 所有 GPG key 已成功匯入"
elif [[ $IMPORTED -gt 0 ]]; then
    echo "⚠ 部分 GPG key 匯入成功 ($IMPORTED/${#MISSING[@]})"
else
    echo "✗ GPG key 自動匯入失敗"
    show_manual_instructions
fi

echo ""
echo "✓ GPG setup check complete"
{{ end -}}
