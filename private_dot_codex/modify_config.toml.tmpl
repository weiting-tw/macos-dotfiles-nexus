#!/usr/bin/env bash
# Codex config merger (chezmoi modify_ script)
#
# 策略：
# - 我們管理的區塊（profile/profiles/model_providers/sandbox/shell/features/mcp_servers）由模板提供
# - Codex CLI runtime 寫入的狀態（projects/notice/tui/hooks）從現有檔案抽出來保留
# - 用 dasel 先規範化整份 TOML，再用 awk 切片，避免多行陣列誤判
#
# chezmoi 執行時：stdin = 當前 ~/.codex/config.toml 內容，stdout = 新內容

set -euo pipefail

# 沒裝 dasel 就吐回原檔不動（讓 brew 安裝階段先補上，下次 apply 才生效）
command -v dasel >/dev/null || { cat; exit 0; }

CURRENT=$(cat)

# 1) 用 dasel 規範化現有 config，再用 awk 抽出 Codex runtime 寫入的 sections
PRESERVED=""
if [[ -n "$CURRENT" ]]; then
  PRESERVED=$(printf '%s\n' "$CURRENT" \
    | dasel -i toml -o toml '' 2>/dev/null \
    | awk '
        /^\[(projects|notice|tui|hooks)([.\]])/ { keep=1 }
        /^\[/ && !match($0, /^\[(projects|notice|tui|hooks)([.\]])/) { keep=0 }
        keep
      ' || true)
fi

# 2) 輸出 desired config（chezmoi template 已先渲染這段）
cat <<'TOML'
{{- if not (env "AZURE_OPENAI_ENDPOINT") }}
preferred_auth_method = "chatgpt"
forced_login_method = "chatgpt"
{{- end }}

{{ template "codex-base.toml" . }}

[features]
goals = true

## mcp

[mcp_servers.playwright]
command = "npx"
args = ["-y", "@playwright/mcp@latest"]

[mcp_servers.context7]
command = "npx"
args = ["-y", "@upstash/context7-mcp"]
env = { "CONTEXT7_API_KEY" = "{{ env "CONTEXT7_API_KEY" }}" }

[mcp_servers.gemini]
command = "npx"
args = ["-y", "gemini-mcp-tool@latest"]

[mcp_servers.pencil]
command = "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64"
args = ["--app", "desktop"]
TOML

# 3) 把保留的 runtime state 接在後面
if [[ -n "$PRESERVED" ]]; then
  printf '\n%s\n' "$PRESERVED"
fi
