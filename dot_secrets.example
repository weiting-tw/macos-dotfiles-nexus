#!/bin/bash
# 敏感環境變數（此檔案不應被 Git 追蹤）
# 複製為 ~/.secrets 後填入真實值

# Azure OpenAI
export OPENAI_API_KEY_openal2=""
export OPENAI_API_KEY_wilbe_m727acgy=""
export AZURE_OPENAI_API_KEY=""
export CODEX_AZURE_OPENAI_API_KEY=""
export OPENAI_API_KEY_app_mfv8vy68=""
export AZURE_RESOURCE_NAME=""

# Azure OpenAI Endpoint (Codex)
export AZURE_OPENAI_ENDPOINT=""

# Google Gemini
export GEMINI_API_KEY=""

# GitLab
export GITLAB_PERSONAL_ACCESS_TOKEN=""
export GITLAB_API_URL=""

# Context7
export CONTEXT7_API_KEY=""

# Perplexity
export PERPLEXITY_API_KEY=""

# Azure Load Balancer (OpenCode)
export AZURE_LB_BEARER_TOKEN=""
export AZURE_LB_ENDPOINT=""

# n8n MCP (Claude Desktop)
export N8N_MCP_TOKEN=""

# npm
export NPM_AUTH_TOKEN=""

# GitHub (Homebrew)
export HOMEBREW_GITHUB_API_TOKEN=""

# Omnara
export OMNARA_BASE_URL=""

# GPG Keys (optional)
export GPG_SIGNING_KEY=""      # Git commit signing (short key ID)
export GPG_DEFAULT_KEY=""      # GPG agent default key (full fingerprint)

# Bitwarden CLI (optional, for GPG key auto-import)
# 不填也能正常運作，會改用互動式登入（手動輸入帳密 + 2FA）
export BW_SERVER=""            # Self-hosted URL (留空 = 互動式選擇)
export BW_CLIENTID=""          # 免互動登入用 (Settings > Security > Keys)，可留空
export BW_CLIENTSECRET=""      # 免互動登入用，可留空
export BW_GPG_ITEM_NAME=""     # Bitwarden 中 GPG key 附件的 item 名稱 (留空 = 搜尋 "GPG")
