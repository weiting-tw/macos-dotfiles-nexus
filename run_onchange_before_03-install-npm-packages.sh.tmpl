{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# Install global npm packages (re-runs when this script changes)
set -euo pipefail

if ! command -v npm &>/dev/null; then
    echo "⚠ npm not found, skipping global packages"
    exit 0
fi

# ===== Global npm packages =====
PACKAGES=(
    "@google/gemini-cli"
    "aicommits"
    "yarn"
)

# Map package name -> command name for PATH-based detection
declare -A PKG_CMD=(
    ["@google/gemini-cli"]="gemini"
    ["aicommits"]="aicommits"
    ["yarn"]="yarn"
)

for pkg in "${PACKAGES[@]}"; do
    cmd="${PKG_CMD[$pkg]:-$pkg}"
    if npm list -g "$pkg" &>/dev/null || command -v "$cmd" &>/dev/null; then
        echo "✓ $pkg already installed"
    else
        echo "Installing $pkg..."
        npm install -g "$pkg"
    fi
done

echo "✓ All npm global packages installed"
{{ end -}}
