{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# Install Homebrew and packages (re-runs when this script changes)
set -euo pipefail

# 不主動要 sudo：formulae 不需要、Cask 清單皆為 drag-drop .app 與字型；
# 若未來加入 pkg 安裝器類 Cask，brew 會在需要時自行提示
# ===== Install Homebrew =====
if ! command -v brew &>/dev/null; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    # Setup PATH for Apple Silicon
    if [[ -f "/opt/homebrew/bin/brew" ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    fi
fi

echo "✓ Homebrew ready"

{{- if index . "is_work" }}
# 公司機器：Cask 安裝到個人 ~/Applications（避免權限問題）
mkdir -p "$HOME/Applications"
export HOMEBREW_CASK_OPTS="--appdir=$HOME/Applications"
{{- end }}

# ===== Base Brewfile =====
brew bundle --file=/dev/stdin <<'BREWFILE'
# CLI 工具
brew "age"           # 加密工具
brew "git"
brew "git-lfs"
brew "diff-so-fancy"
brew "fzf"
brew "ripgrep"
brew "fd"
brew "bat"
brew "eza"
brew "jq"
brew "dasel"        # TOML/JSON/YAML 操作工具（chezmoi modify_ 合併用）
brew "tree"
brew "wget"
brew "gpg"
brew "pinentry-mac"
brew "gh"
brew "zoxide"
brew "htop"          # 系統監控
brew "tldr"          # 簡化版 man pages
brew "prettyping"    # 美化 ping
brew "uv"            # Python 套件管理
brew "bitwarden-cli"  # Bitwarden CLI (GPG key import)
brew "mkcert"        # 本地 HTTPS 憑證
brew "ffmpeg"        # 影音處理
brew "tmux"          # 終端多工器

# 開發工具
brew "node"
brew "python"
{{- if eq (index . "version_manager") "mise" }}
brew "mise"          # 語言版本管理
{{- else }}
brew "asdf"          # 語言版本管理
{{- end }}
tap "oven-sh/bun"
brew "oven-sh/bun/bun"  # JavaScript runtime（OpenCode plugin 需要）

# Cask 應用
cask "bitwarden"
cask "iterm2"
cask "visual-studio-code"
cask "orbstack"      # Docker Desktop 替代方案
cask "postman"       # API 測試
cask "claude"        # Claude Desktop
cask "arc"           # Arc 瀏覽器
cask "beyond-compare" # Beyond Compare 5
cask "google-chrome" # Chrome 瀏覽器
cask "comet"         # Comet
cask "antigravity"   # Google Antigravity

# 字型
cask "font-noto-sans-cjk-tc"
cask "font-source-code-pro"
BREWFILE

echo "✓ Base packages installed"

{{- if index . "has_docker" }}
# ===== Docker packages =====
brew bundle --file=/dev/stdin <<'DOCKERBREW'
brew "docker"   # 已內建 completion，勿另裝 docker-completion（會衝突）
DOCKERBREW
echo "✓ Docker packages installed"
{{- end }}

# ===== Antidote (Zsh Plugin Manager) =====
if [[ ! -d "$HOME/.antidote" ]]; then
    echo "Installing Antidote..."
    git clone --depth=1 https://github.com/mattmc3/antidote.git "$HOME/.antidote"
    echo "✓ Antidote installed"
else
    echo "✓ Antidote already installed"
fi

# ===== Host-specific Brewfile =====
# Check if host-specific Brewfile exists in chezmoi source
HOSTNAME=$(hostname -s)
HOST_BREWFILE="{{ .chezmoi.sourceDir }}/hosts/${HOSTNAME}/Brewfile"
if [[ -f "$HOST_BREWFILE" ]]; then
    echo "Installing host-specific packages for ${HOSTNAME}..."
    brew bundle --file="$HOST_BREWFILE"
    echo "✓ Host-specific packages installed"
fi

echo "✓ All Homebrew packages installed"
{{ end -}}
