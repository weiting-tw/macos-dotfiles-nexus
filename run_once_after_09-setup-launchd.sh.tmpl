{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# Setup launchd agents for auto-sync
set -euo pipefail

LAUNCH_AGENTS="$HOME/Library/LaunchAgents"
LOG_DIR="$HOME/.local/log/dotfiles"
mkdir -p "$LAUNCH_AGENTS" "$LOG_DIR"

# ===== chezmoi auto-update agent =====
CHEZMOI_PLIST="$LAUNCH_AGENTS/com.user.chezmoi-update.plist"
CHEZMOI_BIN="$(command -v chezmoi)"

cat > "$CHEZMOI_PLIST" << PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.chezmoi-update</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>/bin/bash -c '
# launchd 環境沒有使用者 shell env：補 Homebrew PATH（dasel/git 等），
# 並載入 ~/.secrets（模板依賴 AZURE_OPENAI_ENDPOINT 等變數判斷渲染分支，
# 缺少時會產出錯誤設定）
export PATH="/opt/homebrew/bin:/usr/local/bin:\$PATH"
if [ -f "\$HOME/.secrets" ]; then
  set -a; . "\$HOME/.secrets"; set +a
fi
LOGFILE="${LOG_DIR}/chezmoi-update.out.log"
# --force：易變設定檔皆走 modify_ 現有優先合併，直接覆寫是安全的；
# 否則 --no-tty 下遇「檔案已被外部修改」提示會 EOF 中止
${CHEZMOI_BIN} update --force --no-tty 2&gt;&amp;1
EC=\$?
if [ \$EC -ne 0 ]; then
  osascript -e "display notification \"更新失敗，請查看 \$LOGFILE\" with title \"Dotfiles Sync\" subtitle \"chezmoi update 失敗\""
fi
exit \$EC
'</string>
    </array>
    <key>StartInterval</key>
    <integer>43200</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${LOG_DIR}/chezmoi-update.out.log</string>
    <key>StandardErrorPath</key>
    <string>${LOG_DIR}/chezmoi-update.err.log</string>
</dict>
</plist>
PLIST

launchctl unload "$CHEZMOI_PLIST" 2>/dev/null || true
launchctl load "$CHEZMOI_PLIST"
echo "✓ chezmoi auto-update agent installed (every 12 hours)"

# ===== iCloud capture agent =====
ICLOUD_SYNC="{{ .chezmoi.sourceDir }}/scripts/icloud-sync.sh"
if [[ -f "$ICLOUD_SYNC" ]]; then
    ICLOUD_PLIST="$LAUNCH_AGENTS/com.user.icloud-capture.plist"

    cat > "$ICLOUD_PLIST" << PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.icloud-capture</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>/bin/bash -c '
${ICLOUD_SYNC} capture 2&gt;&amp;1
EC=\$?
if [ \$EC -ne 0 ]; then
  osascript -e "display notification \"capture 失敗，請執行: icloud-sync.sh status 檢查 symlink 狀態\" with title \"Dotfiles Sync\" subtitle \"iCloud capture 失敗\""
fi
exit \$EC
'</string>
    </array>
    <key>StartInterval</key>
    <integer>21600</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${LOG_DIR}/icloud-capture.out.log</string>
    <key>StandardErrorPath</key>
    <string>${LOG_DIR}/icloud-capture.err.log</string>
</dict>
</plist>
PLIST

    launchctl unload "$ICLOUD_PLIST" 2>/dev/null || true
    launchctl load "$ICLOUD_PLIST"
    echo "✓ iCloud capture agent installed (every 6 hours)"
fi

# ===== gpg-agent auto-start =====
GPG_PLIST="$LAUNCH_AGENTS/com.user.gpg-agent.plist"
GPGCONF_BIN="$(command -v gpgconf)"

cat > "$GPG_PLIST" << PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.gpg-agent</string>
    <key>ProgramArguments</key>
    <array>
        <string>${GPGCONF_BIN}</string>
        <string>--launch</string>
        <string>gpg-agent</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${LOG_DIR}/gpg-agent.out.log</string>
    <key>StandardErrorPath</key>
    <string>${LOG_DIR}/gpg-agent.err.log</string>
</dict>
</plist>
PLIST

launchctl unload "$GPG_PLIST" 2>/dev/null || true
launchctl load "$GPG_PLIST"
echo "✓ gpg-agent auto-start agent installed"

echo "✓ LaunchAgents setup complete"
{{ end -}}
